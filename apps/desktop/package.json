{
  "name": "@umbra/desktop",
  "version": "0.0.0",
  "private": true,
  "main": "./dist/main.js",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc",
    "start": "electron .",
    "typecheck": "tsc --noEmit",
    "package": "pnpm build && electron-builder"
  },
  "dependencies": {
    "@umbra/shared-types": "workspace:*",
    "electron": "^28.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "electron-builder": "^24.13.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0"
  },
  "build": {
    "appId": "com.umbra.app",
    "productName": "Umbra",
    "directories": {
      "output": "dist/build"
    },
    "files": [
      "dist/**/*",
      "node_modules/**/*"
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
