{
  "name": "@umbra/desktop",
  "version": "0.1.0",
  "private": true,
  "description": "Umbra desktop application - local-first Markdown writing server",
  "author": "CrowKing63",
  "main": "./dist/main.js",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc --build",
    "start": "electron .",
    "typecheck": "tsc --noEmit",
    "package": "pnpm build && electron-builder",
    "pack:win": "electron-builder --win",
    "release": "pnpm build && electron-builder --win --publish=always"
  },
  "dependencies": {
    "@umbra/shared-types": "workspace:*",
    "electron-updater": "^6.1.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.13.0",
    "png-to-ico": "^3.0.1",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0"
  },
  "build": {
    "appId": "com.umbra.app",
    "productName": "Umbra",
    "directories": {
      "output": "dist/build"
    },
    "files": [
      "dist/**/*",
      "node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": "../../apps/server/dist",
        "to": "server",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "../../apps/server/node_modules",
        "to": "server/node_modules",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "../../apps/web/dist",
        "to": "web",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "assets",
        "to": "assets",
        "filter": [
          "**/*"
        ]
      }
    ],
    "publish": {
      "provider": "github",
      "owner": "CrowKing63",
      "repo": "Umbra",
      "releaseType": "release"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "include": "build/installer.nsh"
    }
  }
}